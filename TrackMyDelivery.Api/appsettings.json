{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Storage": {
    "DatabasePath": "../TrackMyDelivery.SharedData/track-my-delivery.db"
  },
  "Messaging": {
    "Enabled": false,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "DeliveryEventsExchange": "delivery-events",
    "TrackingUpdatesQueue": "tracking-timeline",
    "FailedDeliveryEventsExchange": "failed-delivery-events",
    "FailedTrackingUpdatesQueue": "failed-tracking-updates",
    "DeliveryEventRoutePrefix": "delivery",
    "FailedDeliveryEventRoute": "delivery.failed",
    "MaxInFlightDeliveryEvents": 10,
    "MaxDeliveryAttempts": 3
  },
  "AllowedHosts": "*"
}
